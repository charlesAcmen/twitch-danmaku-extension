{
  "manifest_version": 3,
  "name": "Danmaku for Twitch",
  "version": "1.0.0",
  "description": "Displays Twitch chat as scrolling danmaku (bullet comments) on the video player. High-performance, privacy-focused, open-source.",
  "author": "charlesAcmen",
  "homepage_url": "https://github.com/yourusername/twitch-danmaku",
  "permissions": ["storage"],
  "host_permissions": [],
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": [
        "src/interceptor/ws-hook.js",
        "src/interceptor/irc-parser.js",
        "src/interceptor/main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": [
        "src/content/config.js",
        "src/content/danmaku-engine.js",
        "src/content/ui.js",
        "src/content/twitch-player.js",
        "src/content/emote-scanner.js",
        "src/content/main.js"
      ],
      "css": ["css/danmaku.css"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "192": "icons/icon-192.png",
    "512": "icons/icon-512.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "192": "icons/icon-192.png",
      "512": "icons/icon-512.png" 
    },
    "default_title": "Danmaku Settings" 
  }
}