{
  "manifest_version": 3,
  "name": "Danmaku for Twitch", 
  "version": "1.0.0",
  "description": "Overlays Twitch chat as scrolling comments (Danmaku) directly onto the video player.",
  "author": "charlesAcmen",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": [
        "src/interceptor/ws-hook.js",
        "src/interceptor/irc-parser.js",
        "src/interceptor/main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": [
        "src/content/config.js",
        "src/content/danmaku-engine.js",
        "src/content/ui.js",
        "src/content/twitch-player.js",
        "src/content/main.js"
      ],
      "css": ["css/danmaku.css"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Danmaku Settings" 
  }
}